<Window x:Class="InTempo.Classes.View.PlayerMusicale"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        mc:Ignorable="d"
        Style="{StaticResource AppBorderlessDialogWindowStyle}"
        Title="Player Musicale" Height="550" Width="450"
        WindowStartupLocation="CenterOwner"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <Style x:Key="PlayerListViewStyle"
               TargetType="{x:Type ListView}"
               BasedOn="{StaticResource {x:Type ListView}}">
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
        </Style>

        <Style x:Key="PlayerListViewItemStyle"
               TargetType="{x:Type ListViewItem}"
               BasedOn="{StaticResource {x:Type ListViewItem}}">
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="4,2" />
            <Setter Property="Padding" Value="8,4" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppDataGridHoverRowBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppCurrentRowBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource AppAccentDeepBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PlayerSliderStyle"
               TargetType="{x:Type Slider}"
               BasedOn="{StaticResource {x:Type Slider}}">
            <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}" />
            <Setter Property="Background" Value="{DynamicResource AppBorderBrush}" />
        </Style>

        <Style x:Key="PlayerProgressThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Background" Value="{DynamicResource AppAccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                CornerRadius="11"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlayerProgressTrackButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Height="4"
                                CornerRadius="2"
                                Background="{TemplateBinding Background}"
                                VerticalAlignment="Center" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlayerProgressSliderStyle"
               TargetType="{x:Type Slider}"
               BasedOn="{StaticResource {x:Type Slider}}">
            <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}" />
            <Setter Property="Background" Value="{DynamicResource AppSubtleBorderBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid VerticalAlignment="Center">
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource PlayerProgressTrackButtonStyle}"
                                                  Background="{TemplateBinding Foreground}"
                                                  Command="Slider.DecreaseLarge" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource PlayerProgressThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource PlayerProgressTrackButtonStyle}"
                                                  Background="{TemplateBinding Background}"
                                                  Command="Slider.IncreaseLarge" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PART_Track" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlayerActionMiniButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource AppChromeIconButtonStyle}">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="16" />
        </Style>

        <Style x:Key="PlayerTransportButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource AppTransportSecondaryButtonStyle}">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
        </Style>

        <Style x:Key="PlayerTransportPrimaryButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource AppTransportPrimaryButtonStyle}">
            <Setter Property="Width" Value="56" />
            <Setter Property="Height" Value="56" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="22" />
        </Style>
    </Window.Resources>

    <materialDesign:Card Style="{StaticResource AppShellCardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="16,16,16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <iconPacks:PackIconMaterial Kind="MusicCircle" Width="28" Height="28" Foreground="{DynamicResource AppAccentBrush}"/>
                    <TextBlock Text="Player Musicale" Margin="12,0,0,0" Style="{StaticResource AppAccentWindowTitleTextStyle}"/>
                </StackPanel>

                <Button Grid.Column="1" x:Name="BtnChiudi" Click="BtnChiudi_Click" 
                        Style="{StaticResource AppCloseToolButtonStyle}">
                    <iconPacks:PackIconMaterial Kind="Close"
                                                Width="20"
                                                Height="20"
                                                Foreground="{DynamicResource AppAccentBrush}"/>
                </Button>
            </Grid>

            <Separator Grid.Row="0" VerticalAlignment="Bottom" Margin="16,0" Opacity="0.5"/>

            <Grid Grid.Row="1" Margin="16,8">
                <Border Style="{StaticResource AppListContainerBorderStyle}">
                    <ListView x:Name="ListBrani"
                              Style="{StaticResource PlayerListViewStyle}"
                              ItemContainerStyle="{StaticResource PlayerListViewItemStyle}"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="4,8">
                                    <iconPacks:PackIconMaterial Kind="MusicNote"
                                                                VerticalAlignment="Center"
                                                                Margin="0,0,12,0"
                                                                Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"/>
                                    <TextBlock Text="{Binding}"
                                               VerticalAlignment="Center"
                                               FontWeight="Medium"
                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>
            </Grid>

            <materialDesign:Card Grid.Row="2" Style="{StaticResource AppFooterSurfaceCardStyle}">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="TxtBranoCorrente" Grid.Row="0" 
                               Text="Nessun brano in riproduzione" 
                               HorizontalAlignment="Center" 
                               FontWeight="Bold" FontSize="16" 
                               Margin="0,0,0,8" TextTrimming="CharacterEllipsis"/>

                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TxtTempoTrascorso" Grid.Column="0" Text="00:00" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource AppMutedCaptionTextStyle}"/>

                        <Slider x:Name="SliderProgresso" Grid.Column="1" 
                                Style="{StaticResource PlayerProgressSliderStyle}"
                                Minimum="0" Maximum="100" Value="0" 
                                TickFrequency="1" TickPlacement="None"/>

                        <TextBlock x:Name="TxtTempoTotale" Grid.Column="2" Text="00:00" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0" Style="{StaticResource AppMutedCaptionTextStyle}"/>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="BtnApriCartella" Grid.Column="0" Click="BtnApriCartella_Click"
                                Style="{StaticResource PlayerActionMiniButtonStyle}" 
                                ToolTip="Carica cartella brani" Width="40" Height="40">
                            <iconPacks:PackIconMaterial Kind="FolderMusic" Width="20" Height="20"/>
                        </Button>

                        <Button x:Name="BtnPrecedente" Grid.Column="2" Click="BtnPrecedente_Click"
                                Style="{StaticResource PlayerTransportButtonStyle}" 
                                ToolTip="Brano precedente" Width="48" Height="48" Margin="0,0,8,0">
                            <iconPacks:PackIconMaterial Kind="SkipPrevious" Width="28" Height="28"/>
                        </Button>

                        <Button x:Name="BtnPlayPausa" Grid.Column="3" Click="BtnPlayPausa_Click"
                                Style="{StaticResource PlayerTransportPrimaryButtonStyle}" 
                                ToolTip="Play / Pausa" Width="56" Height="56">
                            <iconPacks:PackIconMaterial x:Name="IconaPlayPausa" Kind="Play" Width="32" Height="32"/>
                        </Button>

                        <Button x:Name="BtnSuccessivo" Grid.Column="4" Click="BtnSuccessivo_Click"
                                Style="{StaticResource PlayerTransportButtonStyle}" 
                                ToolTip="Brano successivo" Width="48" Height="48" Margin="8,0,0,0">
                            <iconPacks:PackIconMaterial Kind="SkipNext" Width="28" Height="28"/>
                        </Button>

                        <materialDesign:PopupBox Grid.Column="6" 
                                                 ToolTip="Volume" Padding="0" VerticalAlignment="Center">
                            <materialDesign:PopupBox.ToggleContent>
                                <Border Background="{DynamicResource AppSurfaceBrush}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="8">
                                    <iconPacks:PackIconMaterial Kind="VolumeHigh"
                                                                Width="24"
                                                                Height="24"
                                                                Foreground="{DynamicResource AppAccentDeepBrush}"/>
                                </Border>
                            </materialDesign:PopupBox.ToggleContent>
                            <StackPanel Margin="16" Width="100">
                                <TextBlock Text="Volume" HorizontalAlignment="Center" Margin="0,0,0,8" Style="{StaticResource AppMutedCaptionTextStyle}"/>
                                <Slider x:Name="SliderVolume"
                                        Style="{StaticResource PlayerSliderStyle}"
                                        Minimum="0" Maximum="1" Value="0.5" 
                                        TickFrequency="0.1" TickPlacement="None"/>
                            </StackPanel>
                        </materialDesign:PopupBox>

                    </Grid>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </materialDesign:Card>
</Window>

