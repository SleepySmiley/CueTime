<Window x:Class="InTempo.Classes.View.PlayerMusicale"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        mc:Ignorable="d"
        
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        TextOptions.TextFormattingMode="Ideal" 
        TextOptions.TextRenderingMode="Auto"
        Background="Transparent"
        FontFamily="{DynamicResource MaterialDesignFont}"
        
        Title="Player Musicale" Height="550" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <materialDesign:Card Margin="16" 
                         UniformCornerRadius="16" 
                         Background="{DynamicResource MaterialDesignPaper}"
                         materialDesign:ElevationAssist.Elevation="Dp8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="16,16,16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <iconPacks:PackIconMaterial Kind="MusicCircle" Width="28" Height="28" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                    <TextBlock Text="Player Musicale" FontSize="20" FontWeight="SemiBold" Margin="12,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="1" x:Name="BtnChiudi" Click="BtnChiudi_Click" 
                        Style="{StaticResource MaterialDesignToolButton}" 
                        Foreground="{DynamicResource MaterialDesignBodyLight}"
                        Width="30" Height="30" Padding="0">
                    <iconPacks:PackIconMaterial Kind="Close" Width="20" Height="20"/>
                </Button>
            </Grid>

            <Separator Grid.Row="0" VerticalAlignment="Bottom" Margin="16,0" Opacity="0.5"/>

            <Grid Grid.Row="1" Margin="16,8">
                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8">
                    <ListView x:Name="ListBrani" ScrollViewer.VerticalScrollBarVisibility="Auto" Background="Transparent" BorderThickness="0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="4,8">
                                    <iconPacks:PackIconMaterial Kind="MusicNote" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    <TextBlock Text="{Binding}" VerticalAlignment="Center" FontWeight="Medium"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>
            </Grid>

            <materialDesign:Card Grid.Row="2" 
                                 Margin="0" 
                                 Background="{DynamicResource MaterialDesignDarkSeparatorBackground}" 
                                 UniformCornerRadius="0"
                                 materialDesign:ElevationAssist.Elevation="Dp4">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="TxtBranoCorrente" Grid.Row="0" 
                               Text="Nessun brano in riproduzione" 
                               HorizontalAlignment="Center" 
                               FontWeight="Bold" FontSize="16" 
                               Margin="0,0,0,8" TextTrimming="CharacterEllipsis"/>

                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TxtTempoTrascorso" Grid.Column="0" Text="00:00" FontSize="12" Opacity="0.7" VerticalAlignment="Center" Margin="0,0,8,0"/>

                        <Slider x:Name="SliderProgresso" Grid.Column="1" 
                                Minimum="0" Maximum="100" Value="0" 
                                TickFrequency="1" TickPlacement="None"
                                materialDesign:SliderAssist.OnlyShowFocusVisualWhileDragging="True"/>

                        <TextBlock x:Name="TxtTempoTotale" Grid.Column="2" Text="00:00" FontSize="12" Opacity="0.7" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="BtnApriCartella" Grid.Column="0" Click="BtnApriCartella_Click"
                                Style="{StaticResource MaterialDesignFloatingActionMiniLightButton}" 
                                ToolTip="Carica cartella brani" Width="40" Height="40">
                            <iconPacks:PackIconMaterial Kind="FolderMusic" Width="20" Height="20"/>
                        </Button>

                        <Button x:Name="BtnPrecedente" Grid.Column="2" Click="BtnPrecedente_Click"
                                Style="{StaticResource MaterialDesignToolButton}" 
                                ToolTip="Brano precedente" Width="48" Height="48" Margin="0,0,8,0">
                            <iconPacks:PackIconMaterial Kind="SkipPrevious" Width="28" Height="28"/>
                        </Button>

                        <Button x:Name="BtnPlayPausa" Grid.Column="3" Click="BtnPlayPausa_Click"
                                Style="{StaticResource MaterialDesignFloatingActionButton}" 
                                ToolTip="Play / Pausa" Width="56" Height="56">
                            <iconPacks:PackIconMaterial x:Name="IconaPlayPausa" Kind="Play" Width="32" Height="32"/>
                        </Button>

                        <Button x:Name="BtnSuccessivo" Grid.Column="4" Click="BtnSuccessivo_Click"
                                Style="{StaticResource MaterialDesignToolButton}" 
                                ToolTip="Brano successivo" Width="48" Height="48" Margin="8,0,0,0">
                            <iconPacks:PackIconMaterial Kind="SkipNext" Width="28" Height="28"/>
                        </Button>

                        <materialDesign:PopupBox Grid.Column="6" 
                                                 ToolTip="Volume" Padding="0" VerticalAlignment="Center">
                            <materialDesign:PopupBox.ToggleContent>
                                <iconPacks:PackIconMaterial Kind="VolumeHigh" Width="24" Height="24" Margin="8" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                            </materialDesign:PopupBox.ToggleContent>
                            <StackPanel Margin="16" Width="100">
                                <TextBlock Text="Volume" HorizontalAlignment="Center" Opacity="0.7" Margin="0,0,0,8"/>
                                <Slider x:Name="SliderVolume" Minimum="0" Maximum="1" Value="0.5" 
                                        TickFrequency="0.1" TickPlacement="None"/>
                            </StackPanel>
                        </materialDesign:PopupBox>

                    </Grid>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </materialDesign:Card>
</Window>