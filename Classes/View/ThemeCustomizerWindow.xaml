<Window x:Class="CueTime.Classes.View.ThemeCustomizerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:utilTheme="clr-namespace:CueTime.Classes.Utilities.Theming"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Style="{StaticResource AppBorderlessDialogWindowStyle}"
        Title="Tema Personalizzato"
        Icon="pack://application:,,,/cuetime_icon.ico"
        Width="1380"
        Height="860"
        MinWidth="1240"
        MinHeight="760"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <DataTemplate DataType="{x:Type utilTheme:ThemeColorPickerItem}">
            <Border Margin="0,0,0,10"
                    Padding="12"
                    Style="{StaticResource AppListContainerBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="{Binding Label}"
                                   Style="{StaticResource AppSubtitleTextBlockStyle}"/>
                        <TextBlock Text="{Binding Description}"
                                   Margin="0,3,0,0"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource AppMutedCaptionTextStyle}"/>
                        <TextBlock Text="{Binding HexValue}"
                                   Margin="0,8,0,0"
                                   FontFamily="Consolas"
                                   FontSize="13"
                                   Foreground="{DynamicResource AppMutedTextBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Width="34"
                                Height="34"
                                Margin="0,0,12,0"
                                Background="{Binding PreviewBrush}"
                                BorderBrush="{DynamicResource AppSubtleBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"/>

                        <xctk:ColorPicker Width="170"
                                          SelectedColor="{Binding SelectedColor, Mode=TwoWay}"
                                          UsingAlphaChannel="True"
                                          ShowAvailableColors="True"
                                          ShowStandardColors="True"
                                          ShowRecentColors="True"
                                          ShowDropDownButton="True"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <materialDesign:Card Style="{StaticResource AppShellCardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <materialDesign:Card Grid.Row="0" Style="{StaticResource AppSectionCardStyle}">
                <Grid Margin="16,12"
                      MouseLeftButtonDown="Window_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Tema Personalizzato"
                                   Style="{StaticResource AppAccentWindowTitleTextStyle}"/>
                        <TextBlock Text="Anteprima live della MainWindow a sinistra, palette completa a destra."
                                   Margin="0,4,0,0"
                                   Style="{StaticResource AppMutedCaptionTextStyle}"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Style="{StaticResource AppCloseToolButtonStyle}"
                            ToolTip="Chiudi"
                            Click="BtnAnnulla_Click">
                        <materialDesign:PackIcon Kind="Close"
                                                 Width="26"
                                                 Height="26"
                                                 Foreground="{DynamicResource AppAccentBrush}"/>
                    </Button>
                </Grid>
            </materialDesign:Card>

            <Grid Grid.Row="1"
                  Margin="14,14,14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.25*"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="0.95*"/>
                </Grid.ColumnDefinitions>

                <materialDesign:Card Grid.Column="0"
                                     Style="{StaticResource AppSectionCardStyle}">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Preview MainWindow"
                                   Style="{StaticResource AppSubtitleTextBlockStyle}"/>

                        <Border x:Name="PreviewScope"
                                Grid.Row="1"
                                Margin="0,12,0,0"
                                Style="{StaticResource AppListContainerBorderStyle}"
                                Padding="14"
                                Background="Transparent">
                            <Viewbox Stretch="Uniform">
                                <Grid Width="920"
                                      Height="560"
                                      Background="{DynamicResource AppMainWindowBackdropBrush}">
                                    <Ellipse Width="320"
                                             Height="320"
                                             HorizontalAlignment="Right"
                                             VerticalAlignment="Top"
                                             Margin="0,-150,-90,0"
                                             Fill="{DynamicResource AppBackdropOrbPrimaryBrush}"
                                             IsHitTestVisible="False"/>

                                    <Ellipse Width="360"
                                             Height="360"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Bottom"
                                             Margin="-150,0,0,-180"
                                             Fill="{DynamicResource AppBackdropOrbSecondaryBrush}"
                                             IsHitTestVisible="False"/>

                                    <Ellipse Width="220"
                                             Height="220"
                                             HorizontalAlignment="Right"
                                             VerticalAlignment="Bottom"
                                             Margin="0,0,110,52"
                                             Fill="{DynamicResource AppBackdropOrbTertiaryBrush}"
                                             Opacity="0.9"
                                             IsHitTestVisible="False"/>

                                    <Grid Margin="22">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.35*"/>
                                                <ColumnDefinition Width="0.95*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Style="{StaticResource AppHeroPanelBorderStyle}"
                                                    Padding="18,14">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Text="IN CORSO ORA"
                                                               Style="{StaticResource AppMainEyebrowTextStyle}"/>

                                                    <TextBlock Grid.Row="1"
                                                               Margin="0,12,0,0"
                                                               VerticalAlignment="Center"
                                                               Text="Commenti introduttivi"
                                                               TextWrapping="Wrap"
                                                               Foreground="{DynamicResource AppTextPrimaryBrush}"
                                                               Style="{StaticResource AppMainHeroTitleTextStyle}"/>
                                                </Grid>
                                            </Border>

                                            <Border Grid.Column="1"
                                                    Margin="16,0,0,0"
                                                    Style="{StaticResource AppPanelBorderStyle}"
                                                    Padding="16,12">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Text="DISPLAY PRINCIPALE"
                                                               Style="{StaticResource AppMetricLabelTextStyle}"/>

                                                    <Viewbox Grid.Row="1"
                                                             Height="86"
                                                             Margin="0,8,0,0"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             StretchDirection="DownOnly">
                                                        <TextBlock Text="16:55"
                                                                   FontSize="62"
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                                                    </Viewbox>
                                                </Grid>
                                            </Border>
                                        </Grid>

                                        <Border Grid.Row="1"
                                                Margin="0,0,0,16"
                                                Style="{StaticResource AppPanelBorderStyle}"
                                                Padding="14,14,14,10">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Text="Scaletta completa"
                                                           Foreground="{DynamicResource AppAccentDeepBrush}"
                                                           Style="{StaticResource AppSectionHeaderTextStyle}"/>

                                                <Border Grid.Row="1"
                                                        Margin="0,12,0,0"
                                                        CornerRadius="16"
                                                        BorderBrush="{DynamicResource AppSubtleBorderBrush}"
                                                        BorderThickness="1"
                                                        Background="{DynamicResource AppSurfaceBrush}">
                                                    <Grid Margin="12">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <Grid Margin="0,0,0,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="56"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="110"/>
                                                                <ColumnDefinition Width="110"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="#"
                                                                       HorizontalAlignment="Center"
                                                                       Style="{StaticResource AppMetricLabelTextStyle}"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="Titolo"
                                                                       Style="{StaticResource AppMetricLabelTextStyle}"/>
                                                            <TextBlock Grid.Column="2"
                                                                       Text="Durata"
                                                                       HorizontalAlignment="Center"
                                                                       Style="{StaticResource AppMetricLabelTextStyle}"/>
                                                            <TextBlock Grid.Column="3"
                                                                       Text="Timer"
                                                                       HorizontalAlignment="Center"
                                                                       Style="{StaticResource AppMetricLabelTextStyle}"/>
                                                        </Grid>

                                                        <Border Grid.Row="1"
                                                                CornerRadius="14"
                                                                Padding="8,10"
                                                                Background="{DynamicResource AppCurrentRowBrush}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="56"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="110"/>
                                                                    <ColumnDefinition Width="110"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="1"
                                                                           HorizontalAlignment="Center"
                                                                           Foreground="{DynamicResource AppAccentBrush}"/>
                                                                <TextBlock Grid.Column="1"
                                                                           Text="Commenti introduttivi"
                                                                           Foreground="{DynamicResource AppTextPrimaryBrush}"
                                                                           FontWeight="SemiBold"/>
                                                                <TextBlock Grid.Column="2"
                                                                           Text="01:00"
                                                                           HorizontalAlignment="Center"
                                                                           Foreground="{DynamicResource AppMutedTextBrush}"/>
                                                                <TextBlock Grid.Column="3"
                                                                           Text="00:47"
                                                                           HorizontalAlignment="Center"
                                                                           Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                                                            </Grid>
                                                        </Border>

                                                        <Grid Grid.Row="2"
                                                              Margin="0,8,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="56"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="110"/>
                                                                <ColumnDefinition Width="110"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="2"
                                                                       HorizontalAlignment="Center"
                                                                       Foreground="{DynamicResource AppMutedTextBrush}"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="Gemme spirituali"
                                                                       Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                                                            <TextBlock Grid.Column="2"
                                                                       Text="10:00"
                                                                       HorizontalAlignment="Center"
                                                                       Foreground="{DynamicResource AppMutedTextBrush}"/>
                                                            <TextBlock Grid.Column="3"
                                                                       Text="10:00"
                                                                       HorizontalAlignment="Center"
                                                                       Foreground="{DynamicResource AppMutedTextBrush}"/>
                                                        </Grid>

                                                        <Grid Grid.Row="3"
                                                              Margin="0,10,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="56"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="110"/>
                                                                <ColumnDefinition Width="110"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="3"
                                                                       HorizontalAlignment="Center"
                                                                       Foreground="{DynamicResource AppMutedTextBrush}"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="Lettura biblica"
                                                                       Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                                                            <TextBlock Grid.Column="2"
                                                                       Text="04:00"
                                                                       HorizontalAlignment="Center"
                                                                       Foreground="{DynamicResource AppMutedTextBrush}"/>
                                                            <TextBlock Grid.Column="3"
                                                                       Text="04:00"
                                                                       HorizontalAlignment="Center"
                                                                       Foreground="{DynamicResource AppMutedTextBrush}"/>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="220"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="184"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    MinHeight="102"
                                                    Style="{StaticResource AppPanelBorderStyle}"
                                                    Padding="8,10">
                                                <DockPanel LastChildFill="True">
                                                    <StackPanel DockPanel.Dock="Left"
                                                                Width="54"
                                                                Margin="0,0,8,0"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center">
                                                        <Button Width="50"
                                                                Height="50"
                                                                HorizontalAlignment="Center"
                                                                IsHitTestVisible="False"
                                                                Style="{StaticResource AppChromeIconButtonStyle}">
                                                            <iconPacks:PackIconMaterial Kind="Cog" Width="22" Height="22"/>
                                                        </Button>

                                                        <Button Width="50"
                                                                Height="50"
                                                                Margin="0,4,0,0"
                                                                HorizontalAlignment="Center"
                                                                IsHitTestVisible="False"
                                                                Style="{StaticResource AppChromeIconButtonStyle}">
                                                            <iconPacks:PackIconMaterial Kind="Music" Width="22" Height="22"/>
                                                        </Button>
                                                    </StackPanel>

                                                    <Grid VerticalAlignment="Center">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>

                                                        <TextBlock Text="TEMPO RESIDUO"
                                                                   HorizontalAlignment="Center"
                                                                   Style="{StaticResource AppMetricLabelTextStyle}"/>

                                                        <Viewbox Grid.Row="1"
                                                                 Height="58"
                                                                 Margin="0,4,0,0"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"
                                                                 StretchDirection="DownOnly">
                                                            <TextBlock Text="0:00"
                                                                       Foreground="{DynamicResource AppTextPrimaryBrush}"
                                                                       Style="{StaticResource AppMetricValueTextStyle}"/>
                                                        </Viewbox>
                                                    </Grid>
                                                </DockPanel>
                                            </Border>

                                            <Border Grid.Column="2"
                                                    MinHeight="102"
                                                    Style="{StaticResource AppInsetPanelBorderStyle}"
                                                    Padding="12,10">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Text="CONTROLLI LIVE"
                                                               HorizontalAlignment="Center"
                                                               Style="{StaticResource AppMetricLabelTextStyle}"/>

                                                    <StackPanel Grid.Row="1"
                                                                Orientation="Horizontal"
                                                                HorizontalAlignment="Center"
                                                                Margin="0,6,0,0"
                                                                VerticalAlignment="Center">
                                                        <Button Width="56"
                                                                Height="56"
                                                                Margin="0,0,18,0"
                                                                IsHitTestVisible="False"
                                                                Style="{StaticResource AppTransportSecondaryButtonStyle}">
                                                            <iconPacks:PackIconMaterial Kind="SkipPreviousCircle"
                                                                                        Width="26"
                                                                                        Height="26"/>
                                                        </Button>

                                                        <Button Width="66"
                                                                Height="66"
                                                                IsHitTestVisible="False"
                                                                Style="{StaticResource AppTransportPrimaryButtonStyle}">
                                                            <iconPacks:PackIconMaterial Kind="Play"
                                                                                        Width="32"
                                                                                        Height="32"/>
                                                        </Button>

                                                        <Button Width="56"
                                                                Height="56"
                                                                Margin="18,0,0,0"
                                                                IsHitTestVisible="False"
                                                                Style="{StaticResource AppTransportSecondaryButtonStyle}">
                                                            <iconPacks:PackIconMaterial Kind="SkipNextCircle"
                                                                                        Width="26"
                                                                                        Height="26"/>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <Border Grid.Column="4"
                                                    MinHeight="102"
                                                    Style="{StaticResource AppPanelBorderStyle}"
                                                    Padding="10,10">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Text="MESSAGGI"
                                                               HorizontalAlignment="Center"
                                                               Style="{StaticResource AppMetricLabelTextStyle}"/>

                                                    <Button Grid.Row="1"
                                                            Height="44"
                                                            Margin="0,6,0,0"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            IsHitTestVisible="False"
                                                            Style="{StaticResource AppPrimaryButtonStyle}">
                                                        <StackPanel Orientation="Horizontal"
                                                                    HorizontalAlignment="Center">
                                                            <iconPacks:PackIconMaterial Kind="MessageTextOutline"
                                                                                        Width="17"
                                                                                        Height="17"
                                                                                        Margin="0,0,8,0"/>
                                                            <TextBlock Text="Messaggio"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Viewbox>
                        </Border>
                    </Grid>
                </materialDesign:Card>

                <materialDesign:Card Grid.Column="2"
                                     Style="{StaticResource AppSectionCardStyle}">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Colori"
                                           Style="{StaticResource AppSubtitleTextBlockStyle}"/>
                                <TextBlock Text="Modifica i colori con i picker. Lâ€™anteprima a sinistra si aggiorna subito."
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap"
                                           Style="{StaticResource AppMutedCaptionTextStyle}"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Content="Ripristina Default"
                                    Padding="14,8"
                                    MinWidth="136"
                                    Click="BtnResetTemaPersonalizzato_Click"
                                    Style="{StaticResource AppSecondaryButtonStyle}"/>
                        </Grid>

                        <TabControl Grid.Row="1"
                                    Margin="0,14,0,0"
                                    Background="Transparent"
                                    BorderThickness="0">
                            <TabItem Header="Base">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding ColoriTemaBase}"/>
                                </ScrollViewer>
                            </TabItem>

                            <TabItem Header="Gradienti">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding ColoriTemaAvanzatiGradienti}"/>
                                </ScrollViewer>
                            </TabItem>

                            <TabItem Header="Orb">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding ColoriTemaAvanzatiOrb}"/>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </materialDesign:Card>
            </Grid>

            <materialDesign:Card Grid.Row="2" Style="{StaticResource AppBottomSectionCardStyle}">
                <Grid Margin="16">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="Annulla"
                                Margin="0,0,8,0"
                                Click="BtnAnnulla_Click"
                                Style="{StaticResource AppSubtleFlatButtonStyle}"/>
                        <Button Content="Usa Questo Tema"
                                MinWidth="160"
                                Click="BtnSalva_Click"
                                Style="{StaticResource AppPrimaryButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </materialDesign:Card>
</Window>




