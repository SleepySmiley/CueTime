<Window x:Class="InTempo.Classes.View.ModificaParte"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:media="clr-namespace:System.Windows.Media;assembly=PresentationCore"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        TextOptions.TextFormattingMode="Ideal" 
        TextOptions.TextRenderingMode="Auto"
        FontFamily="{DynamicResource MaterialDesignFont}"
        
        Title="Gestione Parte" Width="450" 
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True" 
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <materialDesign:Card Margin="16" 
                         UniformCornerRadius="12" 
                         Background="{DynamicResource MaterialDesignPaper}"
                         materialDesign:ElevationAssist.Elevation="Dp8">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <materialDesign:Card Grid.Row="0" 
                                 Margin="12,12,12,0" 
                                 UniformCornerRadius="12" 
                                 materialDesign:ElevationAssist.Elevation="Dp4">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="BtnChiudiIcona"
                            Grid.Column="0"
                            Style="{StaticResource MaterialDesignToolButton}"
                            Width="30" Height="30"
                            Padding="0"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            Click="BtnChiudiIcona_Click"
                            ToolTip="Chiudi">
                        <materialDesign:PackIcon Kind="Close" Width="30" Height="30" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                    </Button>

                    <Label x:Name="lblTitolo" 
                           Grid.Column="1"
                           Content="Gestione Parte" 
                           FontSize="20" 
                           FontWeight="SemiBold" 
                           VerticalAlignment="Center"
                           Padding="0"
                           Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="1" 
                                 Margin="12,12,12,0" 
                                 UniformCornerRadius="12" 
                                 materialDesign:ElevationAssist.Elevation="Dp4">

                <StackPanel Margin="16">
                    <TextBox x:Name="TxtNumero" 
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             materialDesign:HintAssist.Hint="Numero (Opzionale)"
                             Text="{Binding NumeroParte}"
                             Margin="0,0,0,20" TextChanged="TxtNumero_TextChanged"/>

                    <TextBox x:Name="TxtNome" 
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             materialDesign:HintAssist.Hint="Titolo Parte"
                             Text="{Binding NomeParte}"
                             Margin="0,0,0,20"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" x:Name="TxtDurata" 
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 materialDesign:HintAssist.Hint="Durata (MM:SS)"
                                 Text="{Binding TempoParteEdit, UpdateSourceTrigger=LostFocus}"/>

                        <xctk:ColorPicker 
                            Grid.Column="2"
                            x:Name="ColorPicker"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            SelectedColor="{Binding ColorPickerColor, Mode=TwoWay}"
                            UsingAlphaChannel="False"
                            ShowAvailableColors="True"
                            ShowStandardColors="True"
                            ShowDropDownButton="True"
                            />



                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="2" 
                                 Margin="12,12,12,12" 
                                 UniformCornerRadius="12" 
                                 materialDesign:ElevationAssist.Elevation="Dp4">

                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right"
                            Margin="16">

                    <Button x:Name="BtnAnnulla" 
                            Content="ANNULLA" 
                            MinWidth="100"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            materialDesign:ButtonAssist.CornerRadius="15"
                            Margin="0,0,8,0" 
                            Click="BtnChiudiIcona_Click"/>

                    <Button x:Name="BtnFatto" 
                            Content="SALVA" 
                            MinWidth="100"
                            materialDesign:ButtonAssist.CornerRadius="15" 
                            Click="BtnFatto_Click"/>

                </StackPanel>
            </materialDesign:Card>

        </Grid>
    </materialDesign:Card>
</Window>