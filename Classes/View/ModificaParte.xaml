<Window x:Class="InTempo.Classes.View.ModificaParte"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:media="clr-namespace:System.Windows.Media;assembly=PresentationCore"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Style="{StaticResource AppTopmostBorderlessDialogWindowStyle}"
        Title="Gestione Parte" Width="450" 
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <materialDesign:Card Style="{StaticResource AppShellCardStyle}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <materialDesign:Card Grid.Row="0" Style="{StaticResource AppSectionCardStyle}">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="BtnChiudiIcona"
                            Grid.Column="0"
                            Style="{StaticResource AppCloseToolButtonStyle}"
                            Margin="0,0,12,0"
                            Click="BtnChiudiIcona_Click"
                            ToolTip="Chiudi">
                        <materialDesign:PackIcon Kind="Close" Width="30" Height="30" Foreground="{StaticResource AppAccentBrush}"/>
                    </Button>

                    <TextBlock x:Name="lblTitolo"
                               Grid.Column="1"
                               Text="Gestione Parte"
                               Style="{StaticResource AppAccentWindowTitleTextStyle}"/>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="1" Style="{StaticResource AppSectionCardStyle}">

                <StackPanel Margin="16">
                    <TextBox x:Name="TxtNumero" 
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             materialDesign:HintAssist.Hint="Numero (Opzionale)"
                             Text="{Binding NumeroParte}"
                             Margin="0,0,0,20" TextChanged="TxtNumero_TextChanged"/>

                    <TextBox x:Name="TxtNome" 
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             materialDesign:HintAssist.Hint="Titolo Parte"
                             Text="{Binding NomeParte}"
                             Margin="0,0,0,20"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" x:Name="TxtDurata" 
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 materialDesign:HintAssist.Hint="Durata (MM:SS)"
                                 Text="{Binding TempoParteEdit, UpdateSourceTrigger=LostFocus}"/>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Colore Parte"
                                        FontSize="12"
                                       Margin="0,0,0,6"/>
                            <xctk:ColorPicker 
                                x:Name="ColorPicker"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                SelectedColor="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ColorPickerColor, Mode=TwoWay}"
                                UsingAlphaChannel="False"
                                ShowAvailableColors="True"
                                ShowStandardColors="True"
                                ShowRecentColors="True"
                                ShowDropDownButton="True"
                                />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="2" Style="{StaticResource AppBottomSectionCardStyle}">

                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right"
                            Margin="16">

                    <Button x:Name="BtnAnnulla" 
                            Content="ANNULLA" 
                            MinWidth="100"
                            Style="{StaticResource AppSecondaryButtonStyle}"
                            Margin="0,0,8,0" 
                            Click="BtnChiudiIcona_Click"/>

                    <Button x:Name="BtnFatto" 
                            Content="SALVA" 
                            MinWidth="100"
                            Style="{StaticResource AppPrimaryButtonStyle}"
                            Click="BtnFatto_Click"/>

                </StackPanel>
            </materialDesign:Card>

        </Grid>
    </materialDesign:Card>
</Window>
