<UserControl x:Class="InTempo.Classes.View.UserControls.VistaOrologio"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:InTempo.Classes.View.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="48">
        <Viewbox>
            <TextBlock x:Name="TxtOrologio" 
                       Text="{Binding TestoSchermoPrincipale}" 
                       Foreground="{Binding OrologioBrush}"
                       Style="{StaticResource AppPresentationTimerTextStyle}"/>
        </Viewbox>
    </Grid>
</UserControl>
