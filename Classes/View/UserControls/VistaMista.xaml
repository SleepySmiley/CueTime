<UserControl x:Class="InTempo.Classes.View.UserControls.VistaMista"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Viewbox Grid.Row="0">
            <TextBlock x:Name="TxtTimer" 
                       Text="{Binding TimerLogics.AdunanzaCorrente.Current.TempoScorrevoleLabel}" 
                       Foreground="{Binding TimerLogics.TimerBrush}" 
                       FontWeight="Bold"/>
        </Viewbox>

        <Viewbox Grid.Row="1">
            <TextBlock x:Name="TxtMessaggio" 
                       Text="{Binding Text}" 
                       Foreground="White"/>
        </Viewbox>
    </Grid>
</UserControl>