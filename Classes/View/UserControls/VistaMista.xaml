<UserControl x:Class="InTempo.Classes.View.UserControls.VistaMista"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Viewbox Grid.Row="0">
            <TextBlock x:Name="TxtTimer" 
                       Text="00:00" 
                       Foreground="White" 
                       FontWeight="Bold"/>
        </Viewbox>

        <Viewbox Grid.Row="1">
            <TextBlock x:Name="TxtMessaggio" 
                       Text="Il tuo messaggio qui" 
                       Foreground="Yellow"/>
        </Viewbox>
    </Grid>
</UserControl>