<UserControl x:Class="InTempo.Classes.View.UserControls.VistaMista"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Viewbox Grid.Row="0">
            <TextBlock x:Name="TxtTimer" 
                       Text="{Binding TimerLogics.AdunanzaCorrente.Current.TempoScorrevoleLabel}" 
                       Foreground="{Binding TimerLogics.TimerBrush}" 
                       Style="{StaticResource AppPresentationTimerTextStyle}"/>
        </Viewbox>

        <Viewbox Grid.Row="1">
            <TextBlock x:Name="TxtMessaggio" 
                       Text="{Binding Text}" 
                       Style="{StaticResource AppPresentationMessageTextStyle}"/>
        </Viewbox>
    </Grid>
</UserControl>
