<UserControl x:Class="InTempo.Classes.View.UserControls.VistaSoloScritta"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="48">
        <Viewbox>
            <TextBlock x:Name="TxtTimer"
                       Text="{Binding Text}"
                       Foreground="{Binding Colore}"
                       Style="{StaticResource AppPresentationMessageTextStyle}"/>
        </Viewbox>
    </Grid>
</UserControl>
