<UserControl x:Class="CueTime.Classes.View.UserControls.VistaSoloTimer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="48">
        <Viewbox>
            <TextBlock x:Name="TxtTimer" 
                       Text="{Binding AdunanzaCorrente.Current.TempoScorrevoleLabel}" 
                       Foreground="{Binding TimerBrush}"
                       Style="{StaticResource AppPresentationTimerTextStyle}"/>
        </Viewbox>
    </Grid>
</UserControl>

