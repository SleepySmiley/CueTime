<UserControl x:Class="InTempo.Classes.View.UserControls.VistaSoloTimer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Viewbox>
            <TextBlock x:Name="TxtTimer" 
               Text="{Binding AdunanzaCorrente.Current.TempoScorrevole, StringFormat={}{0:mm\\:ss}}" 
               Foreground="{Binding TimerBrush}" 
               FontWeight="Bold"/>
        </Viewbox>
    </Grid>
</UserControl>