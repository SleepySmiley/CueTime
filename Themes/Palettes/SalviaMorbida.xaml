<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="AppWindowBackgroundBrush" Color="#F6F1E8" />
    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FFFFFCF7" />
    <SolidColorBrush x:Key="AppSurfaceMutedBrush" Color="#FFF3EEE2" />
    <SolidColorBrush x:Key="AppSurfaceStrongBrush" Color="#FFE4DDCF" />
    <SolidColorBrush x:Key="AppBorderBrush" Color="#FFD3CBBB" />
    <SolidColorBrush x:Key="AppSubtleBorderBrush" Color="#FFE6DFD2" />
    <SolidColorBrush x:Key="AppTextPrimaryBrush" Color="#FF21272A" />
    <SolidColorBrush x:Key="AppMutedTextBrush" Color="#FF6C695F" />
    <SolidColorBrush x:Key="AppAccentBrush" Color="#FF76845F" />
    <SolidColorBrush x:Key="AppAccentSoftBrush" Color="#FFE9EFDF" />
    <SolidColorBrush x:Key="AppAccentDeepBrush" Color="#FF4E5C3F" />
    <SolidColorBrush x:Key="AppDangerBrush" Color="#FFC85A53" />
    <SolidColorBrush x:Key="AppDangerSoftBrush" Color="#14C85A53" />
    <SolidColorBrush x:Key="AppOverlayBrush" Color="#7A0E1724" />
    <SolidColorBrush x:Key="AppCurrentRowBrush" Color="#FFF0ECD8" />
    <SolidColorBrush x:Key="AppToolbarTrayBackgroundBrush" Color="#E6F7F8F0" />
    <SolidColorBrush x:Key="AppDataGridHoverRowBrush" Color="#55FFFFFF" />
    <SolidColorBrush x:Key="AppLoadingOverlayBackgroundBrush" Color="#F2F7F8F0" />
    <SolidColorBrush x:Key="AppInputErrorBrush" Color="#FFC85A53" />
    <SolidColorBrush x:Key="AppPresentationMessageBrush" Color="#E7F0FB" />

    <LinearGradientBrush x:Key="AppPresentationBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#081019" Offset="0" />
        <GradientStop Color="#0E1B2D" Offset="0.55" />
        <GradientStop Color="#14293B" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AppMainWindowBackdropBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFF6F1E8" Offset="0" />
        <GradientStop Color="#FFF0EBDD" Offset="0.48" />
        <GradientStop Color="#FFF9F6F0" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AppHeroSurfaceBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFFFFCF8" Offset="0" />
        <GradientStop Color="#FFF3ECDD" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AppInsetSurfaceBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F7FFFFFF" Offset="0" />
        <GradientStop Color="#FFF5F0E6" Offset="1" />
    </LinearGradientBrush>

    <RadialGradientBrush x:Key="AppBackdropOrbPrimaryBrush" RadiusX="0.8" RadiusY="0.8">
        <GradientStop Color="#55DABF98" Offset="0" />
        <GradientStop Color="#00DABF98" Offset="1" />
    </RadialGradientBrush>

    <RadialGradientBrush x:Key="AppBackdropOrbSecondaryBrush" RadiusX="0.8" RadiusY="0.8">
        <GradientStop Color="#49B7C7AF" Offset="0" />
        <GradientStop Color="#00B7C7AF" Offset="1" />
    </RadialGradientBrush>

    <RadialGradientBrush x:Key="AppBackdropOrbTertiaryBrush" RadiusX="0.8" RadiusY="0.8">
        <GradientStop Color="#40EFE0BF" Offset="0" />
        <GradientStop Color="#00EFE0BF" Offset="1" />
    </RadialGradientBrush>
</ResourceDictionary>
