<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="AppWindowBackgroundBrush" Color="#EEF3F2" />
    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FFFBFEFD" />
    <SolidColorBrush x:Key="AppSurfaceMutedBrush" Color="#FFF1F6F5" />
    <SolidColorBrush x:Key="AppSurfaceStrongBrush" Color="#FFDCE7E5" />
    <SolidColorBrush x:Key="AppBorderBrush" Color="#FFBFD0CC" />
    <SolidColorBrush x:Key="AppSubtleBorderBrush" Color="#FFD6E3E0" />
    <SolidColorBrush x:Key="AppTextPrimaryBrush" Color="#FF18232D" />
    <SolidColorBrush x:Key="AppMutedTextBrush" Color="#FF63727B" />
    <SolidColorBrush x:Key="AppAccentBrush" Color="#FF2E7A78" />
    <SolidColorBrush x:Key="AppAccentSoftBrush" Color="#FFDDF2F0" />
    <SolidColorBrush x:Key="AppAccentDeepBrush" Color="#FF1D4D4C" />
    <SolidColorBrush x:Key="AppDangerBrush" Color="#FFC75454" />
    <SolidColorBrush x:Key="AppDangerSoftBrush" Color="#14C75454" />
    <SolidColorBrush x:Key="AppOverlayBrush" Color="#7A0E1724" />
    <SolidColorBrush x:Key="AppCurrentRowBrush" Color="#FFE3F1EF" />
    <SolidColorBrush x:Key="AppToolbarTrayBackgroundBrush" Color="#E6F0FBF9" />
    <SolidColorBrush x:Key="AppDataGridHoverRowBrush" Color="#55FFFFFF" />
    <SolidColorBrush x:Key="AppLoadingOverlayBackgroundBrush" Color="#F2F0FBF9" />
    <SolidColorBrush x:Key="AppInputErrorBrush" Color="#FFC75454" />
    <SolidColorBrush x:Key="AppPresentationMessageBrush" Color="#E7F0FB" />

    <LinearGradientBrush x:Key="AppPresentationBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#081019" Offset="0" />
        <GradientStop Color="#0E1B2D" Offset="0.55" />
        <GradientStop Color="#14293B" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AppMainWindowBackdropBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFF0F5F4" Offset="0" />
        <GradientStop Color="#FFE8F0EF" Offset="0.52" />
        <GradientStop Color="#FFF6FAF9" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AppHeroSurfaceBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFFFFFFF" Offset="0" />
        <GradientStop Color="#FFF1F8F7" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AppInsetSurfaceBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F7FFFFFF" Offset="0" />
        <GradientStop Color="#FFF1F7F6" Offset="1" />
    </LinearGradientBrush>

    <RadialGradientBrush x:Key="AppBackdropOrbPrimaryBrush" RadiusX="0.8" RadiusY="0.8">
        <GradientStop Color="#4D82C9C1" Offset="0" />
        <GradientStop Color="#0082C9C1" Offset="1" />
    </RadialGradientBrush>

    <RadialGradientBrush x:Key="AppBackdropOrbSecondaryBrush" RadiusX="0.8" RadiusY="0.8">
        <GradientStop Color="#4DA9BDD8" Offset="0" />
        <GradientStop Color="#00A9BDD8" Offset="1" />
    </RadialGradientBrush>

    <RadialGradientBrush x:Key="AppBackdropOrbTertiaryBrush" RadiusX="0.8" RadiusY="0.8">
        <GradientStop Color="#3FD4D3B2" Offset="0" />
        <GradientStop Color="#00D4D3B2" Offset="1" />
    </RadialGradientBrush>
</ResourceDictionary>
