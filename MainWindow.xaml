<Window x:Class="InTempo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dd="urn:gong-wpf-dragdrop"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:InTempo"
        mc:Ignorable="d"
        Style="{StaticResource AppBaseWindowStyle}"
        Title="InTempo"
        Icon="pack://application:,,,/intempo_icon.ico"
        Height="720"
        Width="1180"
        MinHeight="640"
        MinWidth="980"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Grid Background="{StaticResource AppMainWindowBackdropBrush}">
        <Ellipse Width="380"
                 Height="380"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Top"
                 Margin="0,-160,-120,0"
                 Fill="{StaticResource AppBackdropOrbPrimaryBrush}"
                 IsHitTestVisible="False" />

        <Ellipse Width="460"
                 Height="460"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Bottom"
                 Margin="-180,0,0,-240"
                 Fill="{StaticResource AppBackdropOrbSecondaryBrush}"
                 IsHitTestVisible="False" />

        <Ellipse Width="260"
                 Height="260"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,140,70"
                 Fill="{StaticResource AppBackdropOrbTertiaryBrush}"
                 IsHitTestVisible="False"
                 Opacity="0.9" />

        <Grid Margin="28">
            <materialDesign:Card Style="{StaticResource AppShellCardStyle}" Margin="0">
                <Grid Margin="32">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="InTempo"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource AppAccentPageTitleTextStyle}" />

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Top">
                            <Button Width="46"
                                    Height="46"
                                    Margin="0,0,10,0"
                                    Style="{StaticResource AppChromeIconButtonStyle}"
                                    ToolTip="Impostazioni"
                                    Click="Button_Click">
                                <iconPacks:PackIconMaterial Kind="Cog"
                                                            Width="22"
                                                            Height="22"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Center" />
                            </Button>

                            <Button x:Name="btnMusica"
                                    Width="46"
                                    Height="46"
                                    Style="{StaticResource AppChromeIconButtonStyle}"
                                    ToolTip="Musica"
                                    Click="btnMusica_Click">
                                <iconPacks:PackIconMaterial Kind="Music"
                                                            Width="22"
                                                            Height="22"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Center" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="0,0,0,24"
                            Style="{StaticResource AppHeroPanelBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.55*" />
                                <ColumnDefinition Width="0.95*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="IN CORSO ORA"
                                           Style="{StaticResource AppMainEyebrowTextStyle}" />

                                <TextBlock Text="{Binding DatiAdunanza.Current.NomeParte}"
                                           Margin="0,10,0,0"
                                           Foreground="{Binding DatiAdunanza.Current.ColoreParte}"
                                           Style="{StaticResource AppMainHeroTitleTextStyle}" />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Margin="28,0,0,0"
                                    Style="{StaticResource AppInsetPanelBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="DISPLAY PRINCIPALE"
                                               Style="{StaticResource AppMetricLabelTextStyle}" />

                                    <Grid Grid.Row="1" Margin="0,16,0,0">
                                        <Viewbox Height="78" StretchDirection="DownOnly">
                                            <TextBlock x:Name="txtTimer"
                                                       Text="{Binding DatiAdunanza.Current.TempoScorrevoleLabel}"
                                                       FontWeight="Bold"
                                                       Foreground="{Binding DatiAdunanza.Current.ColoreParte}" />
                                        </Viewbox>

                                        <Viewbox Height="78" StretchDirection="DownOnly">
                                            <TextBlock x:Name="txtOrologio"
                                                       Text="{Binding LogicTimer.TestoSchermoPrincipale}"
                                                       FontWeight="Bold"
                                                       Foreground="{Binding DatiAdunanza.Current.ColoreParte}" />
                                        </Viewbox>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2" Margin="0,0,0,24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Scaletta completa"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource AppSectionHeaderTextStyle}" />

                            <Border Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource AppChipBorderStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="CursorMove"
                                                                Width="16"
                                                                Height="16"
                                                                Margin="0,0,8,0"
                                                                Foreground="{StaticResource AppAccentDeepBrush}" />
                                    <TextBlock Text="RIORDINO"
                                               Style="{StaticResource AppChipTextStyle}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="1"
                                Style="{StaticResource AppPanelBorderStyle}"
                                Padding="12">
                            <Grid>
                                <DataGrid x:Name="DataGridAdunanza"
                                          ItemsSource="{Binding DatiAdunanza.Parti}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserResizeRows="False"
                                          CanUserResizeColumns="False"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          SelectionUnit="FullRow"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          CanUserSortColumns="False"
                                          CanUserDeleteRows="False"
                                          CanUserReorderColumns="False"
                                          RowHeaderWidth="0"
                                          RowHeight="54"
                                          ColumnHeaderHeight="46"
                                          BorderThickness="0"
                                          Background="Transparent"
                                          HorizontalGridLinesBrush="{StaticResource AppSubtleBorderBrush}"
                                          VerticalGridLinesBrush="Transparent"
                                          dd:DragDrop.IsDragSource="True"
                                          dd:DragDrop.IsDropTarget="True"
                                          dd:DragDrop.UseDefaultDragAdorner="True"
                                          dd:DragDrop.DefaultDragAdornerOpacity="0.8"
                                          dd:DragDrop.ShowAlwaysDropTargetAdorner="True"
                                          dd:DragDrop.DragDirectlySelectedOnly="True"
                                          dd:DragDrop.SelectDroppedItems="True"
                                          FocusVisualStyle="{x:Null}"
                                          materialDesign:DataGridAssist.SelectedCellBorderBrush="Transparent">

                                    <DataGrid.Resources>
                                        <SolidColorBrush x:Key="MaterialDesign.Brush.DataGrid.Selected" Color="Transparent" />

                                        <Style TargetType="DataGridColumnHeader"
                                               BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                                            <Setter Property="Foreground" Value="{StaticResource AppMutedTextBrush}" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                                            <Setter Property="BorderBrush" Value="{StaticResource AppSubtleBorderBrush}" />
                                            <Setter Property="Padding" Value="14,10" />
                                        </Style>
                                    </DataGrid.Resources>

                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="Padding" Value="14,8" />
                                            <Setter Property="Background" Value="Transparent" />
                                        </Style>
                                    </DataGrid.CellStyle>

                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="FontSize" Value="14" />
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#55FFFFFF" />
                                                </Trigger>
                                                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource AppCurrentRowBrush}" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>

                                    <DataGrid.Columns>
                                        <materialDesign:DataGridTextColumn Header="#"
                                                                           Binding="{Binding NumeroParte}"
                                                                           Width="58"
                                                                           IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                                    <Setter Property="VerticalAlignment" Value="Center" />
                                                    <Setter Property="Foreground" Value="{Binding ColoreParte}" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </materialDesign:DataGridTextColumn>

                                        <materialDesign:DataGridTextColumn Header="Titolo"
                                                                           Binding="{Binding NomeParte}"
                                                                           Width="*"
                                                                           IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center" />
                                                    <Setter Property="Foreground" Value="{Binding ColoreParte}" />
                                                    <Setter Property="FontSize" Value="15" />
                                                    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </materialDesign:DataGridTextColumn>

                                        <materialDesign:DataGridTextColumn Header="Durata"
                                                                           Binding="{Binding TempoParteLabel}"
                                                                           Width="110"
                                                                           IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center" />
                                                    <Setter Property="Foreground" Value="{Binding ColoreParte}" />
                                                    <Setter Property="Opacity" Value="0.7" />
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </materialDesign:DataGridTextColumn>

                                        <materialDesign:DataGridTextColumn Header="Timer"
                                                                           Binding="{Binding TempoScorrevoleLabel}"
                                                                           Width="120"
                                                                           IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center" />
                                                    <Setter Property="Foreground" Value="{Binding ColoreParte}" />
                                                    <Setter Property="FontWeight" Value="Medium" />
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </materialDesign:DataGridTextColumn>

                                        <DataGridTemplateColumn Width="68">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <materialDesign:PopupBox PlacementMode="BottomAndAlignRightEdges"
                                                                                 StaysOpen="False"
                                                                                 Padding="0">
                                                            <materialDesign:PopupBox.ToggleContent>
                                                                <Border Background="{StaticResource AppSurfaceMutedBrush}"
                                                                        BorderBrush="{StaticResource AppSubtleBorderBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="12"
                                                                        Padding="8">
                                                                    <iconPacks:PackIconMaterial Kind="DotsVertical"
                                                                                                Width="18"
                                                                                                Height="18"
                                                                                                Foreground="{StaticResource AppTextPrimaryBrush}" />
                                                                </Border>
                                                            </materialDesign:PopupBox.ToggleContent>

                                                            <StackPanel MinWidth="180" Margin="6">
                                                                <Button Content="Reset"
                                                                        Margin="0,0,0,8"
                                                                        Click="MenuItemReset_Click"
                                                                        Tag="{Binding}"
                                                                        Style="{StaticResource AppSecondaryButtonStyle}" />

                                                                <Button Content="Aggiungi Parte"
                                                                        Margin="0,0,0,8"
                                                                        Click="MenuItemAggiungi_Click"
                                                                        Tag="{Binding}"
                                                                        Style="{StaticResource AppSecondaryButtonStyle}" />

                                                                <Button Content="Modifica Parte"
                                                                        Margin="0,0,0,8"
                                                                        Click="MenuItemModifica_Click"
                                                                        Tag="{Binding}"
                                                                        Style="{StaticResource AppSecondaryButtonStyle}" />

                                                                <Button Content="Elimina"
                                                                        Click="MenuItemEllimina_Click"
                                                                        Tag="{Binding}"
                                                                        Style="{StaticResource AppDangerOutlinedButtonStyle}" />
                                                            </StackPanel>
                                                        </materialDesign:PopupBox>
                                                    </Grid>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Border HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Padding="8"
                                        Background="#F2FFF8F2"
                                        BorderBrush="{StaticResource AppSubtleBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Panel.ZIndex="10"
                                        IsHitTestVisible="False">
                                    <ProgressBar x:Name="prgbar"
                                                 Width="32"
                                                 Height="32"
                                                 Value="50"
                                                 Visibility="Visible"
                                                 IsIndeterminate="True"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 Style="{StaticResource MaterialDesignCircularProgressBar}" />
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource AppPanelBorderStyle}"
                                Padding="20">
                            <StackPanel>
                                <TextBlock Text="TEMPO RESIDUO"
                                           Style="{StaticResource AppMetricLabelTextStyle}" />

                                <TextBlock Text="{Binding DatiAdunanza.TempoResiduoString}"
                                           Margin="0,8,0,0"
                                           Foreground="{Binding LogicTimer.TempoResiduoBrush}"
                                           Style="{StaticResource AppMetricValueTextStyle}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Margin="18,0"
                                Style="{StaticResource AppInsetPanelBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="CONTROLLI TIMER"
                                           HorizontalAlignment="Center"
                                           Style="{StaticResource AppMetricLabelTextStyle}" />

                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Margin="0,16,0,0">
                                    <Button x:Name="BtnIndietro"
                                            Margin="0,0,18,0"
                                            Click="BtnIndietro_Click"
                                            Style="{StaticResource AppTransportSecondaryButtonStyle}"
                                            ToolTip="Precedente">
                                        <iconPacks:PackIconMaterial Kind="SkipPreviousCircle"
                                                                    Width="24"
                                                                    Height="24" />
                                    </Button>

                                    <Button x:Name="BtnPausaRiprendi"
                                            Width="76"
                                            Height="76"
                                            Click="BtnPausaRiprendi_Click"
                                            Style="{StaticResource AppTransportPrimaryButtonStyle}"
                                            ToolTip="Play/Pausa">
                                        <iconPacks:PackIconMaterial Kind="{Binding IconaStatoTimer, FallbackValue=Play}"
                                                                    Width="34"
                                                                    Height="34" />
                                    </Button>

                                    <Button x:Name="BtnAvanti"
                                            Margin="18,0,0,0"
                                            Click="BtnAvanti_Click"
                                            Style="{StaticResource AppTransportSecondaryButtonStyle}"
                                            ToolTip="Successiva">
                                        <iconPacks:PackIconMaterial Kind="SkipNextCircle"
                                                                    Width="24"
                                                                    Height="24" />
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Style="{StaticResource AppPanelBorderStyle}"
                                Padding="20">
                            <StackPanel>
                                <TextBlock Text="SCHERMO SECONDARIO"
                                           Style="{StaticResource AppMetricLabelTextStyle}" />

                                <Button x:Name="btnCommentoSchermo"
                                        Margin="0,12,0,0"
                                        Width="190"
                                        Height="48"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        ToolTip="Commento Schermo"
                                        Click="btnCommentoSchermo_Click"
                                        IsEnabled="False"
                                        Style="{StaticResource AppPrimaryButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="MessageTextOutline"
                                                                    Width="20"
                                                                    Height="20"
                                                                    Margin="0,0,10,0" />
                                        <TextBlock Text="Messaggio"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</Window>
