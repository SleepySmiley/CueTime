<Window x:Class="InTempo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dd="urn:gong-wpf-dragdrop"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:InTempo"
        mc:Ignorable="d"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        TextOptions.TextFormattingMode="Ideal" 
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Title="InTempo" Height="500" Width="800" Loaded="Window_Loaded" Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <materialDesign:Card Grid.Row="0" 
                             Margin="12,12,12,0" 
                             UniformCornerRadius="12" 
                             materialDesign:ElevationAssist.Elevation="Dp4">
            <Grid Margin="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding DatiAdunanza.Current.NomeParte}" 
                           VerticalAlignment="Center"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="{Binding DatiAdunanza.Current.ColoreParte}"
                           TextTrimming="CharacterEllipsis"/>

                <Viewbox Grid.Column="1" Height="48" Margin="16,0,0,0">
                    <TextBlock x:Name="txtTimer" Text="{Binding DatiAdunanza.Current.TempoScorrevoleLabel}"
                               FontWeight="Bold"
                               Foreground="{Binding DatiAdunanza.Current.ColoreParte}"/>
                </Viewbox>
                <Viewbox Grid.Column="1" Height="48" Margin="16,0,0,0">
                    <TextBlock x:Name="txtOrologio" 
                               FontWeight="Bold"
                               Text="{Binding LogicTimer.TestoSchermoPrincipale}"
                               Foreground="{Binding DatiAdunanza.Current.ColoreParte}"/>
                </Viewbox>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="1" 
                             Margin="12,12,12,0" 
                             UniformCornerRadius="12" 
                             materialDesign:ElevationAssist.Elevation="Dp4">

            <DataGrid x:Name="DataGridAdunanza"
                      ItemsSource="{Binding DatiAdunanza.Parti}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      CanUserSortColumns="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      BorderThickness="0"
                      Background="Transparent" 
                      dd:DragDrop.IsDragSource="True"
                      dd:DragDrop.IsDropTarget="True"
                      dd:DragDrop.UseDefaultDragAdorner="True"
                      dd:DragDrop.DefaultDragAdornerOpacity="0.8"
                      dd:DragDrop.ShowAlwaysDropTargetAdorner="True"
                      dd:DragDrop.DragDirectlySelectedOnly="True"
                      dd:DragDrop.SelectDroppedItems="True"
                      FocusVisualStyle="{x:Null}"
                      materialDesign:DataGridAssist.SelectedCellBorderBrush="Transparent">


                <DataGrid.Resources>
                    <!-- MaterialDesign: sfondo riga selezionata -->
                    <SolidColorBrush x:Key="MaterialDesign.Brush.DataGrid.Selected" Color="Transparent"/>

                    <!-- (OPZIONALE) se vuoi eliminare anche l'effetto hover -->
                    <!-- <SolidColorBrush x:Key="MaterialDesign.Brush.DataGrid.RowHoverBackground" Color="Transparent"/> -->
                </DataGrid.Resources>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                <Setter Property="Background" Value="#332196F3"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <materialDesign:DataGridTextColumn Header="#" Binding="{Binding NumeroParte}" Width="Auto" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="{Binding ColoreParte}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </materialDesign:DataGridTextColumn>

                    <materialDesign:DataGridTextColumn Header="Titolo" Binding="{Binding NomeParte}" Width="*" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="{Binding ColoreParte}"/>
                                <Setter Property="FontSize" Value="15"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </materialDesign:DataGridTextColumn>

                    <materialDesign:DataGridTextColumn Header="Durata" Binding="{Binding TempoParteLabel}" Width="Auto" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="{Binding ColoreParte}"/>
                                <Setter Property="Opacity" Value="0.7"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </materialDesign:DataGridTextColumn>

                    <materialDesign:DataGridTextColumn Header="Timer" Binding="{Binding TempoScorrevoleLabel}" Width="Auto" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="{Binding ColoreParte}"/>
                                <Setter Property="FontWeight" Value="Medium"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </materialDesign:DataGridTextColumn>

                    <DataGridTemplateColumn Width="50">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <materialDesign:PopupBox PlacementMode="BottomAndAlignRightEdges" StaysOpen="False" Padding="0">
                                    <materialDesign:PopupBox.ToggleContent>
                                        <iconPacks:PackIconMaterial Kind="DotsVertical" Width="20" Height="20" Foreground="{DynamicResource MaterialDesignBody}"/>
                                    </materialDesign:PopupBox.ToggleContent>

                                    <StackPanel MinWidth="150">
                                        <Button Content="Reset" Click="MenuItemReset_Click" Tag="{Binding}"/>
                                        <Button Content="Aggiungi Parte" Click="MenuItemAggiungi_Click" Tag="{Binding}"/>
                                        <Button Content="Modifica Parte" Click="MenuItemModifica_Click" Tag="{Binding}"/>
                                        <Separator/>
                                        <Button Content="Elimina" Click="MenuItemEllimina_Click" Tag="{Binding}" Foreground="Red"/>
                                    </StackPanel>
                                </materialDesign:PopupBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="1"
                             UniformCornerRadius="14"
                             Padding="4"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Background="Transparent"
                             materialDesign:ElevationAssist.Elevation="Dp0"
                             Panel.ZIndex="10"
                             IsHitTestVisible="False">
            <ProgressBar x:Name="prgbar"
                         Style="{StaticResource MaterialDesignCircularProgressBar}"
                         Value="50"
                         IsIndeterminate="True"
                         Width="30" Height="30"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Visibility="Visible"/>
        </materialDesign:Card>


        <materialDesign:Card Grid.Row="2" 
                             Margin="12,12,12,12" 
                             UniformCornerRadius="12" 
                             materialDesign:ElevationAssist.Elevation="Dp4">
            <Grid Margin="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="TEMPO RESIDUO" FontSize="10" FontWeight="Bold" Opacity="0.5"/>
                    <TextBlock Text="{Binding DatiAdunanza.TempoResiduoString}" 
                               FontSize="20" 
                               FontWeight="Medium"
                               Foreground="{Binding LogicTimer.TempoResiduoBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnIndietro" Click="BtnIndietro_Click"
                            Style="{StaticResource MaterialDesignFloatingActionMiniSecondaryButton}"
                            Margin="0,0,24,0"
                            ToolTip="Precedente">
                        <iconPacks:PackIconMaterial Kind="SkipPreviousCircle" Width="24" Height="24"/>
                    </Button>

                    <Button x:Name="BtnPausaRiprendi" Click="BtnPausaRiprendi_Click"
                            Style="{StaticResource MaterialDesignFloatingActionButton}"
                            Width="64" Height="64"
                            ToolTip="Play/Pausa">
                        <iconPacks:PackIconMaterial Kind="{Binding IconaStatoTimer, FallbackValue=Play}" Width="32" Height="32"/>
                    </Button>

                    <Button x:Name="BtnAvanti" Click="BtnAvanti_Click"
                            Style="{StaticResource MaterialDesignFloatingActionMiniSecondaryButton}"
                            Margin="24,0,0,0"
                            ToolTip="Successiva">
                        <iconPacks:PackIconMaterial Kind="SkipNextCircle" Width="24" Height="24"/>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button x:Name="btnCommentoSchermo" 
                            Content="Messaggio"
                            materialDesign:ButtonAssist.CornerRadius="20"
                            Margin="0,0,10,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom"
                            Width="150" 
                            Height="40"
                            ToolTip="Commento Schermo"
                            Click="btnCommentoSchermo_Click"
                            IsEnabled="False"/>

                    <Button Width="40" 
                            Height="40" 
                            ToolTip="Impostazioni"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            materialDesign:ButtonAssist.CornerRadius="15" Click="Button_Click">
                        <iconPacks:PackIconMaterial Kind="Cog" 
                                                    Width="22" 
                                                    Height="22" 
                                                    VerticalAlignment="Center" 
                                                    HorizontalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Window>