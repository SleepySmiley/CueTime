<Window x:Class="InTempo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dd="urn:gong-wpf-dragdrop"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:InTempo"
        mc:Ignorable="d"
        Style="{StaticResource AppBaseWindowStyle}"
        Title="InTempo"
        Icon="pack://application:,,,/intempo_icon.ico"
        Height="680"
        Width="1140"
        MinHeight="610"
        MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Grid Background="{DynamicResource AppMainWindowBackdropBrush}">
        <Ellipse Width="380"
                 Height="380"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Top"
                 Margin="0,-160,-120,0"
                 Fill="{DynamicResource AppBackdropOrbPrimaryBrush}"
                 IsHitTestVisible="False" />

        <Ellipse Width="460"
                 Height="460"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Bottom"
                 Margin="-180,0,0,-240"
                 Fill="{DynamicResource AppBackdropOrbSecondaryBrush}"
                 IsHitTestVisible="False" />

        <Ellipse Width="260"
                 Height="260"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,140,70"
                 Fill="{DynamicResource AppBackdropOrbTertiaryBrush}"
                 IsHitTestVisible="False"
                 Opacity="0.9" />

        <Grid Margin="26">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.35*" />
                    <ColumnDefinition Width="0.95*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource AppHeroPanelBorderStyle}"
                        Padding="20,14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="IN CORSO ORA"
                                   HorizontalAlignment="Left"
                                   FontSize="14"
                                    Style="{StaticResource AppMainEyebrowTextStyle}" />

                        <Viewbox Grid.Row="1"
                                 Margin="0,6,0,2"
                                 Height="84"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Center"
                                 StretchDirection="DownOnly">
                            <TextBlock Text="{Binding DatiAdunanza.Current.NomeParte}"
                                        FontWeight="SemiBold"
                                        FontSize="36"
                                        TextTrimming="CharacterEllipsis"
                                        Foreground="{DynamicResource AppTextPrimaryBrush}"
                                        Style="{StaticResource AppMainHeroTitleTextStyle}" />
                        </Viewbox>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Margin="16,0,0,0"
                        Style="{StaticResource AppPanelBorderStyle}"
                        Padding="16,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="DISPLAY PRINCIPALE"
                                   HorizontalAlignment="Left"
                                   FontSize="14"
                                    Style="{StaticResource AppMetricLabelTextStyle}" />

                        <Grid Grid.Row="1"
                              Margin="0,4,0,0"
                              VerticalAlignment="Center">
                            <Viewbox Height="92"
                                     StretchDirection="DownOnly"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <TextBlock x:Name="txtTimer"
                                            Text="{Binding DatiAdunanza.Current.TempoScorrevoleLabel}"
                                            FontSize="62"
                                            FontWeight="Bold"
                                            TextAlignment="Center"
                                            Foreground="{DynamicResource AppTextPrimaryBrush}" />
                            </Viewbox>

                            <Viewbox Height="92"
                                     StretchDirection="DownOnly"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <TextBlock x:Name="txtOrologio"
                                            Text="{Binding LogicTimer.TestoSchermoPrincipale}"
                                            FontSize="62"
                                            FontWeight="Bold"
                                            TextAlignment="Center"
                                            Foreground="{DynamicResource AppTextPrimaryBrush}" />
                            </Viewbox>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,0,0,18"
                    Style="{StaticResource AppPanelBorderStyle}"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="18,16,18,10">
                        <TextBlock Text="Scaletta completa"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource AppAccentDeepBrush}"
                                    Style="{StaticResource AppSectionHeaderTextStyle}" />
                    </Grid>

                    <Grid Grid.Row="1" Margin="10,0,10,10">
                        <DataGrid x:Name="DataGridAdunanza"
                                  ItemsSource="{Binding DatiAdunanza.Parti}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserResizeRows="False"
                                  CanUserResizeColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  CanUserSortColumns="False"
                                  CanUserDeleteRows="False"
                                  CanUserReorderColumns="False"
                                  RowHeaderWidth="0"
                                  RowHeight="54"
                                  ColumnHeaderHeight="46"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  HorizontalGridLinesBrush="{DynamicResource AppSubtleBorderBrush}"
                                  VerticalGridLinesBrush="Transparent"
                                  dd:DragDrop.IsDragSource="True"
                                  dd:DragDrop.IsDropTarget="True"
                                  dd:DragDrop.UseDefaultDragAdorner="True"
                                  dd:DragDrop.DefaultDragAdornerOpacity="0.8"
                                  dd:DragDrop.ShowAlwaysDropTargetAdorner="True"
                                  dd:DragDrop.DragDirectlySelectedOnly="True"
                                  dd:DragDrop.SelectDroppedItems="True"
                                  FocusVisualStyle="{x:Null}"
                                  materialDesign:DataGridAssist.SelectedCellBorderBrush="Transparent">

                                    <DataGrid.Resources>
                                        <SolidColorBrush x:Key="MaterialDesign.Brush.DataGrid.Selected" Color="Transparent" />

                                        <Style TargetType="DataGridColumnHeader"
                                               BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                                            <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter Property="FontSize" Value="15" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource AppSubtleBorderBrush}" />
                                            <Setter Property="Padding" Value="14,10" />
                                        </Style>
                                    </DataGrid.Resources>

                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="Padding" Value="14,8" />
                                            <Setter Property="Background" Value="Transparent" />
                                        </Style>
                                    </DataGrid.CellStyle>

                                    <DataGrid.RowStyle>
                                                <Style TargetType="DataGridRow">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="FontSize" Value="15" />
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource AppDataGridHoverRowBrush}" />
                                                </Trigger>
                                                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource AppCurrentRowBrush}" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>

                                    <DataGrid.Columns>
                                        <materialDesign:DataGridTextColumn Header="#"
                                                                           Binding="{Binding NumeroParte}"
                                                                           Width="58"
                                                                           IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                                    <Setter Property="VerticalAlignment" Value="Center" />
                                                    <Setter Property="Foreground" Value="{Binding ColoreParte}" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                    <Setter Property="FontSize" Value="15" />
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </materialDesign:DataGridTextColumn>

                                        <materialDesign:DataGridTextColumn Header="Titolo"
                                                                           Binding="{Binding NomeParte}"
                                                                           Width="*"
                                                                           IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center" />
                                                    <Setter Property="Foreground" Value="{Binding ColoreParte}" />
                                                    <Setter Property="FontSize" Value="16" />
                                                    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </materialDesign:DataGridTextColumn>

                                        <materialDesign:DataGridTextColumn Header="Durata"
                                                                           Binding="{Binding TempoParteLabel}"
                                                                           Width="110"
                                                                           IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center" />
                                                    <Setter Property="Foreground" Value="{Binding ColoreParte}" />
                                                    <Setter Property="FontSize" Value="15" />
                                                    <Setter Property="Opacity" Value="0.7" />
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </materialDesign:DataGridTextColumn>

                                        <materialDesign:DataGridTextColumn Header="Timer"
                                                                           Binding="{Binding TempoScorrevoleLabel}"
                                                                           Width="120"
                                                                           IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center" />
                                                    <Setter Property="Foreground" Value="{Binding ColoreParte}" />
                                                    <Setter Property="FontSize" Value="15" />
                                                    <Setter Property="FontWeight" Value="Medium" />
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </materialDesign:DataGridTextColumn>

                                        <DataGridTemplateColumn Width="68">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <materialDesign:PopupBox PlacementMode="BottomAndAlignRightEdges"
                                                                                 StaysOpen="False"
                                                                                 Padding="0">
                                                            <materialDesign:PopupBox.ToggleContent>
                                                                <Border Background="{DynamicResource AppSurfaceMutedBrush}"
                                                                        BorderBrush="{DynamicResource AppSubtleBorderBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="12"
                                                                        Padding="8">
                                                                    <iconPacks:PackIconMaterial Kind="DotsVertical"
                                                                                                Width="18"
                                                                                                Height="18"
                                                                                                Foreground="{DynamicResource AppTextPrimaryBrush}" />
                                                                </Border>
                                                            </materialDesign:PopupBox.ToggleContent>

                                                            <StackPanel MinWidth="180" Margin="6">
                                                                <Button Content="Reset"
                                                                        Margin="0,0,0,8"
                                                                        Click="MenuItemReset_Click"
                                                                        Tag="{Binding}"
                                                                        Style="{StaticResource AppSecondaryButtonStyle}" />

                                                                <Button Content="Aggiungi Parte"
                                                                        Margin="0,0,0,8"
                                                                        Click="MenuItemAggiungi_Click"
                                                                        Tag="{Binding}"
                                                                        Style="{StaticResource AppSecondaryButtonStyle}" />

                                                                <Button Content="Modifica Parte"
                                                                        Margin="0,0,0,8"
                                                                        Click="MenuItemModifica_Click"
                                                                        Tag="{Binding}"
                                                                        Style="{StaticResource AppSecondaryButtonStyle}" />

                                                                 <Button Content="Elimina"
                                                                         Click="MenuItemElimina_Click"
                                                                         Tag="{Binding}"
                                                                         Style="{StaticResource AppDangerOutlinedButtonStyle}" />
                                                            </StackPanel>
                                                        </materialDesign:PopupBox>
                                                    </Grid>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                        </DataGrid>

                        <Border x:Name="loadingOverlay"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Padding="8"
                                Background="{DynamicResource AppLoadingOverlayBackgroundBrush}"
                                BorderBrush="{DynamicResource AppSubtleBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="18"
                                Panel.ZIndex="10"
                                IsHitTestVisible="False"
                                Visibility="Collapsed">
                            <ProgressBar x:Name="prgbar"
                                         Width="32"
                                         Height="32"
                                         Value="50"
                                         Visibility="Collapsed"
                                         IsIndeterminate="True"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         Style="{StaticResource MaterialDesignCircularProgressBar}" />
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="188" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="184" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        MinHeight="102"
                        Style="{StaticResource AppPanelBorderStyle}"
                        Padding="10,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <materialDesign:PopupBox Grid.Column="0"
                                                 PlacementMode="BottomAndAlignLeftEdges"
                                                 StaysOpen="False"
                                                  Padding="0">
                            <materialDesign:PopupBox.ToggleContent>
                                <Border Width="56"
                                        Height="56"
                                        Background="{DynamicResource AppAccentSoftBrush}"
                                        CornerRadius="18">
                                    <iconPacks:PackIconMaterial Kind="Menu"
                                                                Width="24"
                                                                Height="24"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Foreground="{DynamicResource AppAccentDeepBrush}" />
                                </Border>
                            </materialDesign:PopupBox.ToggleContent>

                            <StackPanel MinWidth="220" Margin="6">
                                <Button Margin="0,0,0,8"
                                        Click="Button_Click"
                                        Style="{StaticResource AppSecondaryButtonStyle}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <iconPacks:PackIconMaterial Kind="Cog" Width="18" Height="18" Margin="0,0,8,0" />
                                        <TextBlock Text="Impostazioni" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button Margin="0,0,0,8"
                                        Click="btnMusica_Click"
                                        Style="{StaticResource AppSecondaryButtonStyle}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <iconPacks:PackIconMaterial Kind="Music" Width="18" Height="18" Margin="0,0,8,0" />
                                        <TextBlock Text="Musica" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button Click="btnStatistiche_Click"
                                        Style="{StaticResource AppPrimaryButtonStyle}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <iconPacks:PackIconMaterial Kind="ChartBoxOutline" Width="18" Height="18" Margin="0,0,8,0" />
                                        <TextBlock Text="Statistiche" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </materialDesign:PopupBox>

                        <Grid Grid.Column="2"
                              VerticalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="TEMPO RESIDUO"
                                       HorizontalAlignment="Center"
                                       Style="{StaticResource AppMetricLabelTextStyle}" />

                            <Viewbox Grid.Row="1"
                                     Height="58"
                                     Margin="0,4,0,0"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     StretchDirection="DownOnly">
                                <TextBlock Text="{Binding DatiAdunanza.TempoResiduoString}"
                                           Foreground="{Binding LogicTimer.TempoResiduoBrush}"
                                           Style="{StaticResource AppMetricValueTextStyle}" />
                            </Viewbox>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        MinHeight="102"
                        Style="{StaticResource AppInsetPanelBorderStyle}"
                        Padding="12,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="CONTROLLI LIVE"
                                    HorizontalAlignment="Center"
                                    Style="{StaticResource AppMetricLabelTextStyle}" />

                        <StackPanel Grid.Row="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,6,0,0"
                                    VerticalAlignment="Center">
                            <Button x:Name="BtnIndietro"
                                    Width="56"
                                    Height="56"
                                    Margin="0,0,18,0"
                                    Click="BtnIndietro_Click"
                                    IsEnabled="False"
                                    Style="{StaticResource AppTransportSecondaryButtonStyle}"
                                    ToolTip="Precedente">
                                <iconPacks:PackIconMaterial Kind="SkipPreviousCircle"
                                                            Width="26"
                                                            Height="26" />
                            </Button>

                            <Button x:Name="BtnPausaRiprendi"
                                    Width="66"
                                    Height="66"
                                    Click="BtnPausaRiprendi_Click"
                                    Style="{StaticResource AppTransportPrimaryButtonStyle}"
                                    ToolTip="Play/Pausa">
                                <iconPacks:PackIconMaterial Kind="{Binding IconaStatoTimer, FallbackValue=Play}"
                                                            Width="32"
                                                            Height="32" />
                            </Button>

                            <Button x:Name="BtnAvanti"
                                    Width="56"
                                    Height="56"
                                    Margin="18,0,0,0"
                                    Click="BtnAvanti_Click"
                                    IsEnabled="False"
                                    Style="{StaticResource AppTransportSecondaryButtonStyle}"
                                    ToolTip="Successiva">
                                <iconPacks:PackIconMaterial Kind="SkipNextCircle"
                                                            Width="26"
                                                            Height="26" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="4"
                        MinHeight="102"
                        Style="{StaticResource AppPanelBorderStyle}"
                        Padding="10,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="MESSAGGI"
                                    HorizontalAlignment="Center"
                                    Style="{StaticResource AppMetricLabelTextStyle}" />

                        <Button x:Name="btnCommentoSchermo"
                                Grid.Row="1"
                                Height="44"
                                Margin="0,6,0,0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                ToolTip="Commento Schermo"
                                Click="btnCommentoSchermo_Click"
                                IsEnabled="False"
                                Style="{StaticResource AppPrimaryButtonStyle}">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <iconPacks:PackIconMaterial Kind="MessageTextOutline"
                                                            Width="17"
                                                            Height="17"
                                                            Margin="0,0,8,0" />
                                <TextBlock Text="Messaggio"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>

